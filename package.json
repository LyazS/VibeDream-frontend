{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate:model-manifest && vite",
    "build": "npm run generate:model-manifest && run-p \"type-check:no-generate {@}\" \"build-only {@}\" --",
    "preview": "vite preview",
    "generate:model-manifest": "node scripts/generate-model-manifest.mjs",
    "build-only": "vite build",
    "type-check": "npm run generate:model-manifest && npm run type-check:no-generate",
    "type-check:no-generate": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@imengyu/vue3-context-menu": "^1.5.2",
    "@mediabunny/mp3-encoder": "^1.27.0",
    "@remixicon/vue": "^4.7.0",
    "@types/markdown-it": "^14.1.2",
    "ali-oss": "^6.23.0",
    "axios": "^1.12.2",
    "dexie": "^4.2.0",
    "github-markdown-css": "^5.8.1",
    "html-to-image": "^1.11.13",
    "lodash": "^4.17.21",
    "markdown-it": "^14.1.0",
    "mediabunny": "^1.27.0",
    "nanoid": "^5.1.6",
    "onnxruntime-web": "^1.26.0",
    "p-limit": "^7.2.0",
    "pinia": "^3.0.3",
    "remixicon": "^4.6.0",
    "vue": "^3.5.18",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/ali-oss": "^6.16.13",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.2.1",
    "@types/wicg-file-system-access": "^2023.10.6",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "jiti": "^2.5.1",
    "naive-ui": "^2.43.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "terser": "^5.44.0",
    "typescript": "~5.9.2",
    "vite": "^7.1.1",
    "vite-plugin-remove-console": "^2.2.0",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vue-tsc": "^3.0.5"
  }
}
